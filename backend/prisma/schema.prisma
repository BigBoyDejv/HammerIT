generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url removed – configure in prisma.config.ts
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Job {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  clientId    Int
  workerId    Int?
  price       Float?
  status      String
  createdAt   DateTime @default(now())
}